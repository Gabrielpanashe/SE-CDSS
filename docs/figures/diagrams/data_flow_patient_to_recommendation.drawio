        <mxCell id="62" value="patient data" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#94A3B8;strokeWidth=2;fontSize=9;fontColor=#94A3B8;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="52" target="51" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="63" value="ranked drugs" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2DD4BF;strokeWidth=2;fontSize=9;fontColor=#2DD4BF;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="51" target="50" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="64" value="log to DB" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#F87171;strokeWidth=2;fontSize=9;fontColor=#F87171;exitX=1;exitY=0.5;entryX=0.5;entryY=0;" edge="1" source="53" target="54" parent="1">
          <mxGeometry relative="1" as="geometry" />
