        <!-- RISK LEVEL LEGEND -->
        <mxCell id="70" value="&lt;b&gt;Risk Level Mapping&lt;/b&gt;" style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#E2E8F0;" vertex="1" parent="1">
          <mxGeometry x="90" y="590" width="200" height="24" as="geometry" />
        </mxCell>
        <mxCell id="71" value="🟢  POSITIVE → Mild Concern" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;fontColor=#4ADE80;" vertex="1" parent="1">
          <mxGeometry x="90" y="614" width="240" height="22" as="geometry" />
        </mxCell>
        <mxCell id="72" value="🟡  NEUTRAL → Moderate Risk" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;fontColor=#FCD34D;" vertex="1" parent="1">
          <mxGeometry x="90" y="636" width="240" height="22" as="geometry" />
        </mxCell>
        <mxCell id="73" value="🔴  NEGATIVE → Severe Adverse Reaction" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;fontColor=#F87171;" vertex="1" parent="1">
          <mxGeometry x="90" y="658" width="280" height="22" as="geometry" />
        </mxCell>
        <mxCell id="74" value="⚠️  Adverse keywords (e.g. 'emergency', 'hospital', 'allergic') escalate to Severe regardless of sentiment class" style="text;html=1;fontSize=9;fontStyle=2;fillColor=#1A1200;strokeColor=#FCD34D;fontColor=#FCD34D;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="90" y="688" width="500" height="30" as="geometry" />
