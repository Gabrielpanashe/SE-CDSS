<mxfile host="app.diagrams.net" version="21.0.0">
  <diagram id="data-flow" name="Data Flow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="1" background="#0D1117">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="2" value="&lt;b style='font-size:16px;'&gt;SE-CDSS — Data Flow Diagram&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:11px;'&gt;Patient Drug Review → Preprocessing → ML Inference → Risk Stratification → Drug Recommendation&lt;/font&gt;" style="text;html=1;fillColor=#0F2944;fontColor=#FFFFFF;align=center;rounded=1;strokeColor=#38BDF8;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="20" width="1494" height="55" as="geometry" />
        </mxCell>

        <!-- ROW 1: Input to Inference -->
        <mxCell id="10" value="&lt;b&gt;1. Patient Input&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px;'&gt;• Drug review text&lt;br&gt;• Patient ID (P-XXXXX)&lt;br&gt;• Drug name&lt;br&gt;• Medical condition&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0EA5E9;strokeColor=#38BDF8;fontColor=#FFFFFF;fontSize=10;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="90" y="120" width="180" height="110" as="geometry" />
        </mxCell>

        <mxCell id="11" value="&lt;b&gt;2. Text Preprocessing&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px;'&gt;• Strip HTML entities&lt;br&gt;• Convert to lowercase&lt;br&gt;• Lemmatization (NLTK)&lt;br&gt;• Remove stopwords&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A855F7;strokeColor=#C084FC;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="120" width="180" height="110" as="geometry" />
        </mxCell>

        <mxCell id="12" value="&lt;b&gt;3. BioBERT Tokenization&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px;'&gt;• WordPiece tokenizer&lt;br&gt;• max_length = 128&lt;br&gt;• [CLS] / [SEP] tokens&lt;br&gt;• Attention masks&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#A78BFA;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="610" y="120" width="180" height="110" as="geometry" />
        </mxCell>

        <mxCell id="13" value="&lt;b&gt;4. BioBERT Inference&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px;'&gt;• 108.3M parameters&lt;br&gt;• Forward pass (CPU)&lt;br&gt;• Softmax probabilities&lt;br&gt;• argmax → prediction&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6D28D9;strokeColor=#A78BFA;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="870" y="120" width="190" height="110" as="geometry" />
        </mxCell>

        <mxCell id="14" value="&lt;b&gt;5. Sentiment Classification&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px;'&gt;• Class label (3-way)&lt;br&gt;• Confidence score (0–1)&lt;br&gt;• Class probabilities&lt;br&gt;[NEG · NEU · POS]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0D9488;strokeColor=#2DD4BF;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1140" y="120" width="200" height="110" as="geometry" />
        </mxCell>

        <!-- Arrows Row 1 -->
        <mxCell id="20" value="raw text" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#94A3B8;strokeWidth=2;fontSize=9;fontColor=#94A3B8;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="10" target="11" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="21" value="cleaned text" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#94A3B8;strokeWidth=2;fontSize=9;fontColor=#94A3B8;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="11" target="12" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="22" value="token IDs" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#94A3B8;strokeWidth=2;fontSize=9;fontColor=#94A3B8;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="12" target="13" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="23" value="logits" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#94A3B8;strokeWidth=2;fontSize=9;fontColor=#94A3B8;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="13" target="14" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- SENTIMENT BRANCHES -->
        <mxCell id="30" value="&lt;b&gt;POSITIVE&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px;'&gt;Confidence ≥ 0.72&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16A34A;strokeColor=#4ADE80;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1390" y="90" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="31" value="&lt;b&gt;NEUTRAL&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px;'&gt;Confidence ≥ 0.55&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D97706;strokeColor=#FCD34D;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1390" y="155" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="32" value="&lt;b&gt;NEGATIVE&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px;'&gt;Confidence ≥ 0.68&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DC2626;strokeColor=#F87171;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1390" y="220" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="33" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#4ADE80;strokeWidth=2;exitX=1;exitY=0.3;entryX=0;entryY=0.5;" edge="1" source="14" target="30" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="34" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#FCD34D;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="14" target="31" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="35" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#F87171;strokeWidth=2;exitX=1;exitY=0.7;entryX=0;entryY=0.5;" edge="1" source="14" target="32" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ROW 2: Risk to Response (right to left) -->
        <mxCell id="50" value="&lt;b&gt;9. API Response&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px;'&gt;• sentiment + confidence&lt;br&gt;• risk_level (string)&lt;br&gt;• top drug recommendations&lt;br&gt;• advisory disclaimer&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0EA5E9;strokeColor=#38BDF8;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="90" y="430" width="180" height="110" as="geometry" />
        </mxCell>

        <mxCell id="51" value="&lt;b&gt;8. Drug Recommendation&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px;'&gt;• Sentiment-weighted score&lt;br&gt;• Filter: condition + allergy&lt;br&gt;• Rank drugs by score&lt;br&gt;• Return top-K alternatives&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0D9488;strokeColor=#2DD4BF;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="430" width="200" height="110" as="geometry" />
        </mxCell>

        <mxCell id="52" value="&lt;b&gt;7. EHR Patient Lookup&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px;'&gt;• Load patient JSON record&lt;br&gt;• Get condition profile&lt;br&gt;• Retrieve known allergies&lt;br&gt;• Current medications list&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#475569;strokeColor=#94A3B8;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="630" y="430" width="200" height="110" as="geometry" />
        </mxCell>

        <mxCell id="53" value="&lt;b&gt;6. Risk Stratification&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px;'&gt;Positive → Mild Concern&lt;br&gt;Neutral → Moderate Risk&lt;br&gt;Negative → Severe Adverse&lt;br&gt;Keyword escalation rules&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EF4444;strokeColor=#F87171;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="910" y="430" width="210" height="110" as="geometry" />
        </mxCell>

        <mxCell id="54" value="&lt;b&gt;5b. Database Logging&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px;'&gt;• Write PredictionLog record&lt;br&gt;• Persist: sentiment · risk&lt;br&gt;• patient_id · drug · timestamp&lt;br&gt;• SQLite via SQLAlchemy&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#DC2626;strokeColor=#F87171;fontColor=#FFFFFF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1200" y="425" width="230" height="120" as="geometry" />
        </mxCell>

        <!-- Arrows Row 2 -->
        <mxCell id="60" value="sentiment result" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#94A3B8;strokeWidth=2;fontSize=9;fontColor=#94A3B8;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" source="53" target="14" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1015" y="330" />
