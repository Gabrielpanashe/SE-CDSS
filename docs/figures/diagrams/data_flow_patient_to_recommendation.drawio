        <mxCell id="61" value="risk level" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#F87171;strokeWidth=2;fontSize=9;fontColor=#F87171;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" source="53" target="52" parent="1">
          <mxGeometry relative="1" as="geometry" />
