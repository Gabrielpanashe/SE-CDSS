        <!-- NOTES -->
        <mxCell id="80" value="&lt;b&gt;Database Indices&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px;'&gt;• idx_patient_id  (patient_id ASC) — clinician dashboard query&lt;br&gt;• idx_timestamp   (timestamp DESC) — trend ordering&lt;br&gt;• idx_condition   (condition) — condition-filtered lookups&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A1200;strokeColor=#FCD34D;fontColor=#FCD34D;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="480" width="400" height="85" as="geometry" />
        </mxCell>

        <mxCell id="81" value="&lt;b&gt;Data Constraints &amp;amp; Validation&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px;'&gt;• sentiment IN ('positive','neutral','negative') — enforced by model output&lt;br&gt;• confidence BETWEEN 0.0 AND 1.0 — enforced by Pydantic schema&lt;br&gt;• risk_level IN ('Mild Concern','Moderate Risk','Severe Adverse Reaction')&lt;br&gt;• timestamp DEFAULT CURRENT_TIMESTAMP — auto-set on insert&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0A1E0A;strokeColor=#4ADE80;fontColor=#86EFAC;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="580" width="400" height="100" as="geometry" />
        </mxCell>

        <mxCell id="82" value="&lt;b&gt;Seeded Data&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px;'&gt;scripts/seed_patients.py populates 287 realistic&lt;br&gt;PredictionLog records for all 50 EHR patients&lt;br&gt;(P-00001 to P-00050) spanning 90 days&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#060E20;strokeColor=#60A5FA;fontColor=#93C5FD;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="480" width="280" height="80" as="geometry" />
        </mxCell>

        <mxCell id="83" value="&lt;b&gt;Pydantic Request Schema (POST /feedback)&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px;'&gt;review: str  (required)&lt;br&gt;patient_id: Optional[str]&lt;br&gt;drug_name: Optional[str]&lt;br&gt;condition: Optional[str]&lt;br&gt;model: str = 'biobert' | 'baseline'&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#200A0A;strokeColor=#F87171;fontColor=#FCA5A5;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="480" width="280" height="110" as="geometry" />
        </mxCell>

