                    <mxGeometry x="480" y="225" width="210" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="P3" value="&lt;b&gt;&lt;font style=&quot;font-size:16px;&quot;&gt;3&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;b&gt;&lt;font style=&quot;font-size:14px;&quot;&gt;Sentiment Inference&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;predict_bert.py / predict.py&lt;br&gt;BioBERT (F1: 0.802)&lt;br&gt;TF-IDF+LR (F1: 0.791)&lt;/font&gt;" style="ellipse;html=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2.5;fontColor=#000000;fontSize=13;verticalAlign=middle;align=center;" vertex="1" parent="1">
