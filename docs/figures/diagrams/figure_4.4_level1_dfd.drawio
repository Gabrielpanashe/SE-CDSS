                <mxCell id="P4" value="&lt;b&gt;&lt;font style=&quot;font-size:16px;&quot;&gt;4&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;b&gt;&lt;font style=&quot;font-size:14px;&quot;&gt;Risk Mapping +&lt;br&gt;Keyword Escalation&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;risk_mapper.py&lt;br&gt;10 adverse keywords&lt;/font&gt;" style="ellipse;html=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2.5;fontColor=#000000;fontSize=13;verticalAlign=middle;align=center;" vertex="1" parent="1">
