                <!-- ═══════════════ CALLOUT BOX — P4 Keywords ═══════════════ -->
                <mxCell id="callout" value="&lt;b&gt;&lt;font style=&quot;font-size:13px;&quot;&gt;⚠  Keyword Escalation Triggers (10)&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;&quot;&gt;1.   suicidal&lt;br&gt;2.   chest pain&lt;br&gt;3.   difficulty breathing&lt;br&gt;4.   severe allergic reaction&lt;br&gt;5.   anaphylaxis&lt;br&gt;6.   seizure / convulsions&lt;br&gt;7.   overdose&lt;br&gt;8.   unconscious&lt;br&gt;9.   severe bleeding&lt;br&gt;10. stroke / heart attack&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1.5;fontColor=#000000;fontSize=12;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;spacingRight=8;" vertex="1" parent="1">
