                <mxCell id="P6" value="&lt;b&gt;&lt;font style=&quot;font-size:16px;&quot;&gt;6&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;b&gt;&lt;font style=&quot;font-size:14px;&quot;&gt;Drug Recommendation&lt;br&gt;Scoring&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot;&gt;recommender.py&lt;br&gt;0.33×guideline + 0.33×ehr&lt;br&gt;+ 0.33×sentiment&lt;/font&gt;" style="ellipse;html=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2.5;fontColor=#000000;fontSize=13;verticalAlign=middle;align=center;" vertex="1" parent="1">
