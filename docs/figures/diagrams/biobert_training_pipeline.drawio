                <mxCell id="41" value="&lt;b&gt;H1: Macro F1 ≥ 80%?&lt;/b&gt;&lt;br&gt;&lt;b&gt;H2: BioBERT &gt; Baseline?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#15803D;strokeColor=#4ADE80;fontColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
