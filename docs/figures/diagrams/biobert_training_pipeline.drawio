                <mxCell id="40" value="&lt;b&gt;10. Model Evaluation&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;&#39;&gt;Macro F1 · Weighted F1&lt;br&gt;Per-class Precision &amp;amp; Recall&lt;br&gt;Confusion matrix&lt;br&gt;Test set only (8,000 samples)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16A34A;strokeColor=#4ADE80;fontColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1290" y="160" width="290" height="130" as="geometry"/>
