    <diagram id="biobert-train" name="BioBERT Training Pipeline">
        <mxGraphModel dx="777" dy="1568" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" background="#0D1117" math="0" shadow="1">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="2" value="&lt;font color=&quot;#ffffff&quot;&gt;&lt;font face=&quot;Tahoma&quot; style=&quot;font-size: 48px;&quot;&gt;&lt;b&gt;SE-CDSS — BioBERT Fine-Tuning Pipeline&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;/font&gt;" style="text;html=1;fillColor=#0F2944;fontColor=#FFFFFF;align=center;rounded=1;strokeColor=#FFFFFF;verticalAlign=middle;shadow=0;" parent="1" vertex="1">
                    <mxGeometry x="210" y="-80" width="1344" height="145" as="geometry"/>
                </mxCell>
                <mxCell id="3" value="&lt;b&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;PHASE 1: Data Preparation&lt;/font&gt;&lt;/b&gt;" style="text;html=1;fontSize=10;fontStyle=1;fillColor=#0A1525;strokeColor=#60A5FA;rounded=1;fontColor=#93C5FD;" parent="1" vertex="1">
                    <mxGeometry x="60" y="76" width="370" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="4" value="&lt;b&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;PHASE 2: Model Setup&lt;/font&gt;&lt;/b&gt;" style="text;html=1;fontSize=10;fontStyle=1;fillColor=#160A2E;strokeColor=#A78BFA;rounded=1;fontColor=#C4B5FD;" parent="1" vertex="1">
                    <mxGeometry x="460" y="76" width="320" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="5" value="&lt;b&gt;&lt;font color=&quot;#ffffff&quot;&gt;PHASE 3: Training Loop (3 Epochs)&lt;/font&gt;&lt;/b&gt;" style="text;html=1;fontSize=10;fontStyle=1;fillColor=#1A0900;strokeColor=#FB923C;rounded=1;fontColor=#FDBA74;" parent="1" vertex="1">
                    <mxGeometry x="895" y="70" width="335" height="54" as="geometry"/>
                </mxCell>
                <mxCell id="6" value="&lt;b&gt;PHASE 4: Evaluation &amp;amp; Save&lt;/b&gt;" style="text;html=1;fontSize=10;fontStyle=1;fillColor=#0A1E0A;strokeColor=#4ADE80;rounded=1;fontColor=#86EFAC;" parent="1" vertex="1">
                    <mxGeometry x="1270" y="80" width="295" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="394" style="edgeStyle=none;html=1;exitX=0.93;exitY=0.5;exitDx=0;exitDy=0;exitPerimeter=0;" edge="1" parent="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="330" y="190.09523809523807" as="targetPoint"/>
                        <mxPoint x="266" y="190" as="sourcePoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="11" value="&lt;b&gt;2. Random Sampling&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;&#39;&gt;SAMPLE_SIZE = 40,000&lt;br&gt;Stratified by sentiment&lt;br&gt;POS: 26,468 · NEG: 8,723&lt;br&gt;NEU: 4,809 (imbalanced)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D97706;strokeColor=#FCD34D;fontColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="80" y="290" width="200" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="12" value="&lt;b&gt;3. Text Cleaning&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;&#39;&gt;Strip HTML entities&lt;br&gt;Lowercase conversion&lt;br&gt;Lemmatization (spaCy/NLTK)&lt;br&gt;39,999 rows after cleaning&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A855F7;strokeColor=#C084FC;fontColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="80" y="450" width="200" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="13" value="&lt;b&gt;4. Train / Test Split&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;&#39;&gt;80% Train: 31,999 samples&lt;br&gt;20% Test:    8,000 samples&lt;br&gt;Saved to biobert_test_data.pkl&lt;br&gt;(shared with baseline model)&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#0EA5E9;strokeColor=#38BDF8;fontColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="60" y="610" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="14" value="&lt;b&gt;Training Set (31,999)&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;&#39;&gt;X_train · y_train_labels&lt;br&gt;Used for: BioBERT fine-tuning&lt;br&gt;AND baseline TF-IDF retraining&lt;br&gt;(ensures fair H2 comparison)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0D1E3A;strokeColor=#60A5FA;fontColor=#E2E8F0;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="80" y="790" width="200" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="15" value="&lt;b&gt;Test Set (8,000)&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;&#39;&gt;X_test · y_test_labels&lt;br&gt;Held out — never seen&lt;br&gt;during training&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#38BDF8;fontColor=#E2E8F0;fontSize=10;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1020" width="220" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="16" value="&lt;b&gt;5. Class Weight Computation&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;&#39;&gt;compute_class_weight(&#39;balanced&#39;)&lt;br&gt;NEGATIVE  = 1.529×&lt;br&gt;NEUTRAL   = 2.773× (minority)&lt;br&gt;POSITIVE  = 0.504×&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0D9488;strokeColor=#2DD4BF;fontColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="360" y="790" width="220" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="20" value="&lt;b&gt;6. Load BioBERT Base&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;&#39;&gt;dmis-lab/biobert-base-cased-v1.2&lt;br&gt;Pre-trained: 18GB PubMed + PMC&lt;br&gt;12 transformer layers&lt;br&gt;Hidden size: 768&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#A78BFA;fontColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="500" y="135" width="220" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="21" value="&lt;b&gt;7. Add Classification Head&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;&#39;&gt;Linear(768 → 3)&lt;br&gt;num_labels = 3&lt;br&gt;[NEGATIVE · NEUTRAL · POSITIVE]&lt;br&gt;108.3M total parameters&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6D28D9;strokeColor=#A78BFA;fontColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="510" y="290" width="220" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="22" value="&lt;b&gt;8. BioBERT Tokenization&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;&#39;&gt;AutoTokenizer (WordPiece)&lt;br&gt;max_length = 128&lt;br&gt;padding = &#39;max_length&#39;&lt;br&gt;return_tensors = &#39;pt&#39;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#5B21B6;strokeColor=#A78BFA;fontColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="510" y="480" width="220" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="23" value="&lt;b&gt;9. DataLoader Setup&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;&#39;&gt;BATCH_SIZE = 16&lt;br&gt;shuffle = True (train)&lt;br&gt;SentimentDataset wrapper&lt;br&gt;~2,000 batches/epoch&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4C1D95;strokeColor=#A78BFA;fontColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="510" y="645" width="220" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="30" value="" style="rounded=1;fillColor=#1A0900;strokeColor=#FB923C;strokeWidth=2;dashed=0;" parent="1" vertex="1">
                    <mxGeometry x="890" y="140" width="340" height="920" as="geometry"/>
                </mxCell>
                <mxCell id="31" value="&lt;b&gt;Training Loop — 3 Epochs&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;color:#FDBA74;&#39;&gt;lr = 2e-5 · AdamW optimizer&lt;br&gt;Repeat for each batch (~2,000 per epoch)&lt;/font&gt;" style="text;html=1;fontSize=10;fontColor=#FDBA74;align=center;" parent="1" vertex="1">
                    <mxGeometry x="910" y="135" width="320" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="32" value="&lt;b&gt;Forward Pass&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;&#39;&gt;model(input_ids, attention_mask)&lt;br&gt;Output: logits [batch × 3]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D97706;strokeColor=#FCD34D;fontColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="900" y="200" width="300" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="33" value="&lt;b&gt;Weighted CrossEntropyLoss&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;&#39;&gt;weight=[1.529, 2.773, 0.504]&lt;br&gt;Penalises NEUTRAL misclassification&lt;br&gt;Drives minority class F1 up&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DC2626;strokeColor=#F87171;fontColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="900" y="330" width="300" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="34" value="&lt;b&gt;Backward Pass&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;&#39;&gt;loss.backward()&lt;br&gt;Gradient computation (autograd)&lt;br&gt;Clip gradients (max_norm=1.0)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EA580C;strokeColor=#FB923C;fontColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="890" y="467.5" width="320" height="135" as="geometry"/>
                </mxCell>
                <mxCell id="35" value="&lt;b&gt;AdamW Optimizer Step&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;&#39;&gt;optimizer.step()&lt;br&gt;scheduler.step() (linear warmup)&lt;br&gt;optimizer.zero_grad()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B45309;strokeColor=#FCD34D;fontColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="890" y="630" width="320" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="36" value="&lt;b&gt;Per-Epoch Log&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:9px;&#39;&gt;avg_loss · elapsed time&lt;br&gt;Step progress (every 100 steps)&lt;br&gt;Epoch 1→2→3&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#78350F;strokeColor=#FB923C;fontColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="900" y="805" width="300" height="145" as="geometry"/>
                </mxCell>
                <mxCell id="37" value="next batch" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#FCD34D;strokeWidth=2;fontSize=9;fontColor=#FCD34D;exitX=1;exitY=0.5;entryX=1;entryY=0.5;curved=1;" parent="1" source="35" target="32" edge="1">
