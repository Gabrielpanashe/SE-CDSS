# Virtual environment
venv/
.venv/

# Python cache/build artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# Environment and secrets
.env
.env.*

# Local databases
*.db
*.sqlite3

# Model artifacts (keep large binaries out of git)
models/baseline/*.pkl
models/baseline/*.joblib
models/bert/
# BioBERT fine-tuned weights — 414 MB, exceeds GitHub 100 MB limit
models/biobert_sentiment/model.safetensors
models/biobert_sentiment/*.safetensors

# Notebook checkpoints
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Data policy
data/raw/
data/processed/

# Dissertation and planning documents (private - do not push to GitHub)
*.docx
*.doc

# Claude Code internal memory (local only)
.claude/

# Large binary test data (regenerated by train_biobert.py)
docs/results/biobert_test_data.pkl

# Temp lock files
~$*

# Next.js frontend
frontend-next/.next/
frontend-next/node_modules/
frontend-next/.env.local